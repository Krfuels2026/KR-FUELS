    ('admin', '$2b$10$PLACEHOLDER_HASH', 'System Administrator', 'super_admin');

-- Grant super_admin access to all bunks
INSERT INTO user_bunk_access (user_id, bunk_id)
    SELECT u.id, b.id FROM users u, bunks b WHERE u.username = 'admin';
